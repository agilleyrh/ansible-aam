AAM_ENVIRONMENT=development
AAM_DATABASE_URL=postgresql+psycopg://aam:aam@postgres:5432/aam
AAM_REDIS_URL=redis://redis:6379/0
AAM_SECRET_KEY=replace-with-a-real-secret
AAM_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
AAM_GATEWAY_TRUSTED_PROXY=true
AAM_ALLOW_DEV_BYPASS=true
AAM_DEFAULT_SYNC_INTERVAL_MINUTES=5
AAM_SYNC_JOB_TIMEOUT_MINUTES=15
AAM_SCHEDULER_INTERVAL_SECONDS=60
